NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=
REDIS_URL=
STORAGE_DIR=./data/private-storage
MANUAL_PACK_DIR=./data/manual-packs

NO_PAID_DATA_API=true
DISABLE_PAID_MARKET_DATA=true
DISABLE_NEWS_SCRAPING=true

AI_MODE=manual
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MAX_OPENAI_DAILY_COST_USD=1.00
MAX_OPENAI_DAILY_REQUESTS=300

ENABLE_FUTU=false
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111
FUTU_PERMISSION_CONFIRMED=false

ENABLE_JIN10_MANUAL=true
ENABLE_WALLSTREETCN_MANUAL=true
ENABLE_FUTU_NEWS_MANUAL=true
ENABLE_TWSE_PUBLIC=true
ENABLE_TPEX_PUBLIC=true
ENABLE_MOPS_PUBLIC=true
ENABLE_RSS_PUBLIC=false
ENABLE_LINE_PUSH=false

OCR_ENABLED=false
OCR_PROVIDER=tesseract
OCR_LANG=chi_tra+eng
OCR_MIN_TEXT_LENGTH=10
OCR_MAX_IMAGE_BYTES=5242880
FILE_INGEST_ENABLED=true
FILE_MAX_BYTES=10485760
FILE_TEXT_MAX_CHARS=12000
FILE_FULL_TEXT_MAX_CHARS=50000

LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_PUSH_TARGET_ID=
LINE_ALLOWED_USER_IDS=
LINE_ALLOWED_USER_HASHES=
USER_HASH_SECRET=change-me
GPT_ACTION_BEARER_TOKEN=change-me-too
ADMIN_TOKEN=
