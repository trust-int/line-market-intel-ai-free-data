NODE_ENV=production
PORT=3000
TZ=Asia/Taipei

DATABASE_URL=

NO_PAID_DATA_API=true
DISABLE_PAID_MARKET_DATA=true
DISABLE_NEWS_SCRAPING=true

OFFICIAL_DATA_MODE=auto
AI_MODE=manual

ENABLE_TWSE_PUBLIC=true
ENABLE_TPEX_PUBLIC=true
ENABLE_MOPS_PUBLIC=true

ENABLE_JIN10_MANUAL=true
ENABLE_WALLSTREETCN_MANUAL=true
ENABLE_FUTU=false
FUTU_PERMISSION_CONFIRMED=false

LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ALLOWED_USER_IDS=
LINE_ALLOWED_USER_HASHES=
USER_HASH_SECRET=

ENABLE_LINE_PUSH=false
LINE_PUSH_TARGET_ID=
LINE_TEST_TARGET_ID=

OCR_ENABLED=false
OCR_PROVIDER=tesseract
OCR_LANG=chi_tra+eng
OCR_MIN_TEXT_LENGTH=10
OCR_MAX_IMAGE_BYTES=5242880

GPT_ACTION_BEARER_TOKEN=
ADMIN_TOKEN=
NEWS_INGEST_ALLOWED_SOURCES=manual_test,manual_admin,line_manual,line_manual_pack,line_image_manual,line_image_ocr,jin10,wallstreetcn,futu-news,twse_public,tpex_public,mops_public,rss_public

MAX_OPENAI_DAILY_COST_USD=1.00
MAX_OPENAI_DAILY_REQUESTS=300

NODE_EXTRA_CA_CERTS=
